# ============================================
# BG AI Software Factory — Environment Config
# ============================================

# Required: NextAuth Secret (generate with: openssl rand -base64 48)
NEXTAUTH_SECRET="CHANGE-ME-generate-a-strong-random-string"

# Required: Set to your production URL
NEXTAUTH_URL="http://localhost:3000"

# Required: Database (SQLite default, no change needed)
DATABASE_URL="file:./dev.db"

# Required: DeepSeek API Key (get from https://platform.deepseek.com)
DEEPSEEK_API_KEY=""

# Optional: Ollama VPS (if running local AI models)
OLLAMA_BASE_URL="http://localhost:11434"

# Optional: Pinecone Vector DB
PINECONE_API_KEY=""
